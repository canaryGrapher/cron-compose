# Copy to /etc/croncompose/agent.env and edit. The systemd unit picks it up at
# start. Restart with: systemctl restart croncompose-agent

# host:port of the mTLS gRPC endpoint
CONTROL_PLANE_ADDR=cc.example.com:9090

# base URL for the one-time REST enroll call
CONTROL_PLANE_HTTP=https://cc.example.com/api/v1

# server name to verify against in TLS
CONTROL_PLANE_SNI=cc.example.com

# where the agent keeps identity, TLS material, job cache, and the outbox
DATA_DIR=/var/lib/croncompose
